# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# uv
/uv.lock.tmp

# Reclaim runtime data — never commit real scan indexes or quarantine manifests
data/*.db
data/*.sqlite
data/quarantine/
data/scan-index/

# evals/test_dedup.py scratch trees — created outside a system Temp dir on purpose (pytest's
# own tmp_path lives under %TEMP%, which would confound the keep-heuristic's Downloads/Temp
# fixture cases), cleaned up by the test fixture but ignored as a backstop.
data/_test_scratch/

# User's real config (may contain personal deny/allow paths) — config.example.toml is committed
config.toml

# IDE / OS
.vscode/
.idea/
Thumbs.db
Desktop.ini
